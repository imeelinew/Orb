{
  "manifestVersion": 1,
  "id": "com.eli.orb.example.open-vscode",
  "name": "打开 VS Code",
  "desc": "通过 executable 模块协议调用 VS Code。",
  "version": "1.0.0",
  "displayOrder": 1000,
  "icon": {
    "symbol": "curlybraces",
    "gradient": ["#4AA3FF", "#1D5CFF"]
  },
  "runtime": {
    "kind": "executable",
    "adapter": null,
    "executable": "bin/main"
  },
  "defaultEnabled": false,
  "permissions": ["automation"],
  "capabilities": [
    {
      "id": "open",
      "name": "打开 VS Code",
      "desc": "启动 Visual Studio Code。",
      "command": "open"
    }
  ],
  "settings": [
    {
      "key": "appName",
      "title": "App 名称",
      "type": "string",
      "defaultValue": "Visual Studio Code"
    }
  ]
}
